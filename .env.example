# =============================================================================
# Enterprise RAG System - Environment Configuration
# =============================================================================

# Application
APP_NAME=EnterpriseRAG
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-to-a-secure-random-string
API_HOST=0.0.0.0
API_PORT=8000

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@postgres:5432/ragdb
DATABASE_SYNC_URL=postgresql://raguser:ragpass@postgres:5432/ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpass
POSTGRES_DB=ragdb

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (Object Storage)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-documents
MINIO_USE_SSL=false

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

# Azure OpenAI (set DEFAULT_LLM_PROVIDER=azure_openai to use)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Default LLM
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_TEMPERATURE=0.1

# Embeddings
DEFAULT_EMBEDDING_PROVIDER=openai
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Vector Store
DEFAULT_VECTOR_STORE=pgvector

# Document Processing
MAX_UPLOAD_SIZE_MB=100
SUPPORTED_FILE_TYPES=pdf,docx,txt,md,csv,xlsx,pptx,html,json
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Auth
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
ALLOW_REGISTRATION=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Telemetry
ENABLE_TELEMETRY=false
OTEL_EXPORTER_ENDPOINT=http://jaeger:4317
